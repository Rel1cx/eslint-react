{
  "name": "@local/testkit",
  "version": "0.0.0",
  "private": true,
  "description": "Shared test construction kit for ESLint React's unit tests and rule tests.",
  "homepage": "https://github.com/Rel1cx/eslint-react",
  "bugs": {
    "url": "https://github.com/Rel1cx/eslint-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rel1cx/eslint-react.git",
    "directory": ".pkgs/testkit"
  },
  "license": "MIT",
  "author": "Rel1cx",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "build:docs": "typedoc",
    "lint:publish": "publint",
    "lint:ts": "tsl",
    "publish": "node --run build:docs && node --run lint:publish"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^8.65.0",
    "@typescript-eslint/rule-tester": "^8.65.0",
    "@typescript-eslint/types": "^8.65.0",
    "@typescript-eslint/typescript-estree": "^8.65.0",
    "@typescript-eslint/utils": "^8.65.0"
  },
  "devDependencies": {
    "@local/configs": "workspace:*",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "eslint": "^10.7.0",
    "expect-type": "^1.4.0",
    "tsdown": "^0.22.13",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
