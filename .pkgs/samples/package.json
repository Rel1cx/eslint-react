{
  "name": "@local/samples",
  "version": "0.0.0",
  "private": true,
  "description": "Sample code for testing and documentation purposes.",
  "homepage": "https://github.com/Rel1cx/eslint-react",
  "bugs": {
    "url": "https://github.com/Rel1cx/eslint-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rel1cx/eslint-react.git",
    "directory": ".pkgs/samples"
  },
  "license": "MIT",
  "author": "Rel1cx",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "build:docs": "typedoc",
    "lint:publish": "publint",
    "lint:ts": "tsl",
    "publish": "pnpm run build:docs && pnpm run lint:publish"
  },
  "devDependencies": {
    "@eslint-react/kit": "workspace:*",
    "@local/configs": "workspace:*",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@tsconfig/vite-react": "^8.0.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/types": "^8.61.0",
    "@typescript-eslint/utils": "^8.61.0",
    "eslint": "^10.5.0",
    "tsdown": "^0.22.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
