{
  "name": "@eslint-react/monorepo",
  "version": "5.3.2-beta.1",
  "private": true,
  "description": "Monorepo for eslint-plugin-react-[x, jsx, rsc, dom, web-api, naming-convention].",
  "keywords": [
    "react",
    "eslint",
    "eslint-react",
    "eslint-plugin",
    "eslint-plugin-react-x",
    "eslint-plugin-react-jsx",
    "eslint-plugin-react-rsc",
    "eslint-plugin-react-dom",
    "eslint-plugin-react-web-api",
    "eslint-plugin-react-naming-convention",
    "@eslint-react/eslint-plugin"
  ],
  "homepage": "https://github.com/Rel1cx/eslint-react",
  "bugs": {
    "url": "https://github.com/Rel1cx/eslint-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rel1cx/eslint-react.git"
  },
  "license": "MIT",
  "author": "Rel1cx",
  "type": "module",
  "scripts": {
    "build": "pnpm run update:all && pnpm run build:pkgs && pnpm run build:packages && pnpm run build:plugins",
    "build:docs": "pnpm -r --stream --filter \"./packages/*\" run build:docs",
    "build:packages": "pnpm -r --stream --filter \"./packages/*\" run build",
    "build:plugins": "pnpm -r --stream --filter \"./plugins/*\" run build",
    "build:pkgs": "pnpm -r --stream --filter \"./.pkgs/*\" run build",
    "build:website": "pnpm run update:website && pnpm -F \"./apps/website\" run build",
    "format:check": "dprint check",
    "format:write": "dprint fmt",
    "generate:changelog": "tsx ./scripts/generate-changelog.ts",
    "lint": "pnpm run lint:deps && pnpm run lint:publish && pnpm run lint:ts && pnpm run lint:es && pnpm run lint:examples",
    "lint:deps": "skott -m file-tree -e .ts -s",
    "lint:es": "eslint . --max-warnings 100 --concurrency=auto",
    "lint:examples": "pnpm m -F \"./examples/*\" run lint",
    "lint:mdx": "mdxlint **/*.mdx -o",
    "lint:publish": "pnpm m run lint:publish",
    "lint:ts": "pnpm m run lint:ts",
    "lint:website": "pnpm -F \"./apps/website\" run lint",
    "prepare": "pnpm run build",
    "rename:rule": "tsx ./scripts/rename-rule.ts",
    "scaffold:rule": "tsx ./scripts/scaffold-rule.ts",
    "sort:package-json": "pnpm m exec sort-package-json -q package.json && dprint fmt",
    "test": "vitest run --logHeapUsage",
    "update:all": "pnpm run update:version && pnpm run update:readme && pnpm run update:website",
    "update:readme": "tsx ./scripts/update-readme.ts",
    "update:version": "tsx ./scripts/update-version.ts",
    "update:website": "tsx ./scripts/update-website.ts",
    "verify:configs": "tsx ./scripts/verify-configs.ts",
    "verify:rule-docs": "tsx ./scripts/verify-rule-docs.ts"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@eslint-react/eslint-plugin": "workspace:*",
    "@eslint/compat": "^2.0.5",
    "@local/configs": "workspace:*",
    "@local/eff": "workspace:*",
    "@rbxts/react": "^17.3.7-ts.1",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.58.2",
    "@typescript-eslint/rule-tester": "^8.58.2",
    "@typescript-eslint/types": "^8.58.2",
    "ansis": "^4.2.0",
    "dedent": "^1.7.2",
    "dprint": "^0.54.0",
    "effect": "^3.21.1",
    "eslint": "^10.2.1",
    "eslint-plugin-fast-import": "^2.2.1",
    "mdxlint": "^1.0.0",
    "preact": "^10.29.1",
    "publint": "^0.3.18",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "skott": "^0.35.10",
    "sort-package-json": "^3.6.1",
    "tinyglobby": "^0.2.16",
    "ts-pattern": "^5.9.0",
    "tsdown": "^0.21.9",
    "tsl": "^1.0.30",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
