{
  "name": "@eslint-react/cfa",
  "version": "3.0.0-beta.72",
  "description": "ESLint React's TSESTree AST utility module for static analysis of control flows",
  "homepage": "https://github.com/Rel1cx/eslint-react",
  "bugs": {
    "url": "https://github.com/Rel1cx/eslint-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rel1cx/eslint-react.git",
    "directory": "packages/utilities/cfa"
  },
  "license": "MIT",
  "author": "Rel1cx",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "./package.json"
  ],
  "scripts": {
    "build": "tsdown --dts-resolve",
    "lint:publish": "publint",
    "lint:ts": "tsl",
    "publish": "pnpm run build && pnpm run lint:publish"
  },
  "devDependencies": {
    "@local/configs": "workspace:*",
    "@typescript-eslint/types": "canary",
    "@typescript-eslint/typescript-estree": "canary",
    "tsdown": "^0.21.0-beta.2"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "typescript": "*"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
